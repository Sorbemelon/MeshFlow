# MeshFlow v2 environment example. Do not put real secrets here.

# App
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:3000
ALLOW_DEMO_RESET_USAGE=true
DEMO_RETENTION_DAYS=3

# Metadata database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/meshflow

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
S3_SESSION_PREFIX=meshflow-demo

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA_PREFIX=MF_DEMO

# dbt
DBT_PROFILES_DIR=
DBT_PROJECT_DIR=
DBT_TARGET=dev

# OpenAI - primary for analysis plan generation
OPENAI_API_KEY=
OPENAI_MODEL=

# Gemini - primary for semantic suggestions and insight generation
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_MODEL_1=
GEMINI_MODEL_2=
GEMINI_MODEL_3=
