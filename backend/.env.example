# MeshFlow v2 backend environment
APP_NAME=MeshFlow API
APP_ENV=development
APP_VERSION=0.1.0
APP_DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost:3000

# Metadata database only.
# Local SQLite is allowed for metadata development only; it is not an analytical engine.
DATABASE_URL=sqlite:///./.local/meshflow_metadata.db

DEMO_SESSION_RETENTION_DAYS=3
MAX_DEMO_DATASETS_PER_SESSION=1
MAX_UPLOADED_DATASETS_PER_SESSION=1
MAX_UPLOAD_FILE_SIZE_MB=5
MAX_TOTAL_UPLOAD_SIZE_MB=10
MAX_SUCCESSFUL_ANALYSIS_RUNS_PER_SESSION=8
MAX_DASHBOARD_CARDS_PER_SESSION=8
MAX_CHARTS_PER_ANALYSIS=3
DASHBOARDS_PER_SESSION=1
ALLOW_DEMO_RESET_USAGE=false

# Production example:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/meshflow

# Future phases only. These are intentionally unused in Phase 1.
AWS_REGION=
S3_BUCKET_NAME=
S3_UPLOAD_PREFIX=meshflow-demo
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_STAGE_NAME=

DBT_RUNTIME_DIR=./.local/dbt
DBT_PROJECTS_DIR=./.local/dbt_projects
DBT_PROFILES_DIR=
DBT_TARGET_NAME=dev
DBT_THREADS=1

OPENAI_API_KEY=
OPENAI_MODEL=

GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_MODEL_1=
GEMINI_MODEL_2=
